# Application
NODE_ENV=development
PORT=3001
API_PREFIX=api/v1

# CORS
CORS_ORIGINS=http://localhost:3000

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production
JWT_REFRESH_EXPIRES_IN=7d

# Database
DATABASE_URL=postgresql://chaincred:password@localhost:5432/chaincred_db
DB_POOL_MIN=10
DB_POOL_MAX=50
DB_CONNECTION_TIMEOUT=30000

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Blockchain
ALCHEMY_API_KEY=your-alchemy-api-key
ALCHEMY_RPC_URL=https://polygon-amoy.g.alchemy.com/v2/your-api-key
CHAIN_ID=80002
CONTRACT_ADDRESS=0x...
PRIVATE_KEY=your-private-key-without-0x-prefix
GAS_LIMIT=500000
MAX_GAS_PRICE=100
CONFIRMATIONS=2

# AWS S3
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
S3_BUCKET_NAME=chaincred-certificates

# Email (SendGrid)
SENDGRID_API_KEY=your-sendgrid-api-key
EMAIL_FROM=noreply@chaincred.com
EMAIL_FROM_NAME=ChainCred

# Monitoring
SENTRY_DSN=your-sentry-dsn
SENTRY_ENVIRONMENT=development

# Rate Limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100
