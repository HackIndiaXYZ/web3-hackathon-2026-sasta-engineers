// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  ISSUER
  STUDENT
  VERIFIER
}

enum CredentialStatus {
  PENDING
  PROCESSING
  ISSUED
  FAILED
  REVOKED
  EXPIRED
}

enum VerificationResult {
  VERIFIED
  INVALID
  REVOKED
  TAMPERED
}

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model User {
  id            String   @id @default(uuid())
  name          String
  email         String?  @unique
  passwordHash  String?  @map("password_hash")
  walletAddress String?  @unique @map("wallet_address")
  role          UserRole
  emailVerified Boolean  @default(false) @map("email_verified")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  credentials Credential[] @relation("StudentCredentials")
  issuer      Issuer?

  @@index([email])
  @@index([walletAddress])
  @@index([role])
  @@map("users")
}

model Issuer {
  id               String   @id @default(uuid())
  userId           String   @unique @map("user_id")
  organizationName String   @map("organization_name")
  domain           String?  @unique
  walletAddress    String   @unique @map("wallet_address")
  verified         Boolean  @default(false)
  contactEmail     String?  @map("contact_email")
  contactPhone     String?  @map("contact_phone")
  logoUrl          String?  @map("logo_url")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  // Relations
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  credentials Credential[]

  @@index([walletAddress])
  @@index([verified])
  @@map("issuers")
}

model Credential {
  id              String           @id @default(uuid())
  studentId       String?          @map("student_id")
  issuerId        String           @map("issuer_id")
  credentialHash  String           @unique @map("credential_hash")
  txHash          String?          @unique @map("tx_hash")
  metadataUrl     String?          @map("metadata_url")
  fileUrl         String           @map("file_url")
  qrCodeUrl       String?          @map("qr_code_url")
  metadata        Json             @default("{}")
  status          CredentialStatus @default(PENDING)
  revoked         Boolean          @default(false)
  revokedAt       DateTime?        @map("revoked_at")
  revokedReason   String?          @map("revoked_reason")
  expiryDate      DateTime?        @map("expiry_date")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  // Relations
  student          User?              @relation("StudentCredentials", fields: [studentId], references: [id], onDelete: SetNull)
  issuer           Issuer             @relation(fields: [issuerId], references: [id], onDelete: Restrict)
  verificationLogs VerificationLog[]
  blockchainJobs   BlockchainJob[]

  @@index([credentialHash])
  @@index([studentId])
  @@index([issuerId])
  @@index([txHash])
  @@index([status])
  @@index([revoked])
  @@index([createdAt])
  @@map("credentials")
}

model VerificationLog {
  id                 String             @id @default(uuid())
  credentialId       String             @map("credential_id")
  verifierIp         String?            @map("verifier_ip")
  verificationResult VerificationResult @map("verification_result")
  metadata           Json               @default("{}")
  createdAt          DateTime           @default(now()) @map("created_at")

  // Relations
  credential Credential @relation(fields: [credentialId], references: [id], onDelete: Cascade)

  @@index([credentialId])
  @@index([createdAt])
  @@map("verification_logs")
}

model BlockchainJob {
  id           String    @id @default(uuid())
  credentialId String    @map("credential_id")
  status       JobStatus @default(PENDING)
  txHash       String?   @map("tx_hash")
  retryCount   Int       @default(0) @map("retry_count")
  errorMessage String?   @map("error_message")
  jobData      Json      @default("{}") @map("job_data")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  // Relations
  credential Credential @relation(fields: [credentialId], references: [id], onDelete: Cascade)

  @@index([credentialId])
  @@index([status])
  @@index([createdAt])
  @@map("blockchain_jobs")
}
